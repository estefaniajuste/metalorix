# PostgreSQL (local Docker)
DATABASE_URL=postgresql://metalorix:metalorix_dev@localhost:5432/metalorix

# Twelve Data API (free tier: 800 req/day)
# Get yours at https://twelvedata.com/account/api-keys
TWELVE_DATA_API_KEY=

# Secret for cron endpoint authentication (generate any random string)
CRON_SECRET=

# Gemini AI (for content generation)
GEMINI_API_KEY=

# Resend (for email alerts)
RESEND_API_KEY=

# Google OAuth (for "Continue with Google" login)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
